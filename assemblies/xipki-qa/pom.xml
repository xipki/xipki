<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>org.xipki.assembly</groupId>
    <artifactId>assemblies</artifactId>
    <version>6.6.0</version>
  </parent>
  <artifactId>xipki-qa</artifactId>
  <packaging>pom</packaging>
  <name>XiPKI :: ${project.artifactId}</name>
  <dependencies>
    <dependency>
      <groupId>org.xipki.assembly</groupId>
      <artifactId>xipki-setup</artifactId>
      <version>${project.version}</version>
      <type>pom</type>
    </dependency>
  </dependencies>
  <build>
    <resources>
      <resource>
        <directory>src/main/filtered</directory>
        <filtering>true</filtering>
      </resource>
      <resource>
        <directory>src/main/unfiltered</directory>
        <filtering>false</filtering>
      </resource>
    </resources>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-resources-plugin</artifactId>
        <executions>
          <execution>
            <id>filter</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>resources</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <!--  include additional artifacts -->
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-dependency-plugin</artifactId>
        <executions>
          <execution>
            <id>copy-dummy-servlet-war</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>copy</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/t2/xipki-dummy/tomcat/webapps</outputDirectory>
              <stripVersion>true</stripVersion>
              <artifactItems>
                <artifactItem>
                  <groupId>org.xipki.servlet</groupId>
                  <artifactId>dummy-servlet</artifactId>
                  <version>${project.version}</version>
                  <type>war</type>
                </artifactItem>
              </artifactItems>
            </configuration>
          </execution>
          <!--execution>
            <id>copy-prepare-jar</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>copy</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/setup/lib</outputDirectory>
              <stripVersion>true</stripVersion>
              <artifactItems>
                <artifactItem>
                  <groupId>org.slf4j</groupId>
                  <artifactId>slf4j-api</artifactId>
                  <version>${slf4j.version}</version>
                </artifactItem>
                <artifactItem>
                  <groupId>org.slf4j</groupId>
                  <artifactId>slf4j-simple</artifactId>
                  <version>${slf4j.version}</version>
                </artifactItem>
              </artifactItems>
            </configuration>
          </execution-->
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.karaf.tooling</groupId>
        <artifactId>karaf-maven-plugin</artifactId>
        <extensions>true</extensions>
        <executions>
          <execution>
            <id>add-features-to-repo</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>features-add-to-repository</goal>
            </goals>
            <configuration>
              <repository>${project.build.directory}/t2/xipki-qa/system</repository>
              <descriptors>
                <descriptor>mvn:org.xipki/karaf-features/${project.version}/xml/features</descriptor>
              </descriptors>
              <features>
                <!-- apache karaf -->
                <feature>hidden-do-not-call-me</feature>
                <feature>framework</feature>
                <feature>shell</feature>
                <feature>log</feature>
                <feature>bundle</feature>
                <feature>feature</feature>
                <feature>scr</feature>
                <!-- xipki -->
                <feature>xipki-bc-lts</feature>
                <feature>xipki-bc-fips</feature>
                <feature>xipki-pki-client</feature>
                <feature>xipki-ca-mgmt</feature>
                <feature>xipki-qa</feature>
              </features>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-antrun-plugin</artifactId>
        <executions>
          <execution>
            <phase>prepare-package</phase>
            <configuration>
              <target>
                <gunzip src="../xipki-setup/target/xipki-setup-${project.version}-bclts.tar.gz"/>
                <untar src="../xipki-setup/target/xipki-setup-${project.version}-bclts.tar"
                   dest="${project.build.directory}"/>
                <delete file="../xipki-setup/target/xipki-setup-${project.version}-bclts.tar"/>

                <move file="${project.build.directory}/xipki-setup-${project.version}/xipki-mgmt-cli/etc/org.apache.karaf.features.cfg"
                  todir="${project.build.directory}/setup/bc-lts"/>

                <replace file="${project.build.directory}/setup/bc-lts/org.apache.karaf.features.cfg"
                  token="xipki-ca-mgmt" value="xipki-pki-client,xipki-ca-mgmt,xipki-qa"/>

                <copy file="${project.build.directory}/setup/bc-lts/org.apache.karaf.features.cfg"
                  todir="${project.build.directory}/setup/bc-fips"/>
                <replace file="${project.build.directory}/setup/bc-fips/org.apache.karaf.features.cfg"
                  token="xipki-bc-lts" value="xipki-bc-fips"/>
              </target>
            </configuration>
            <goals>
              <goal>run</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-assembly-plugin</artifactId>
        <executions>
          <execution>
            <id>main</id>
            <phase>package</phase>
            <goals>
              <goal>single</goal>
            </goals>
            <configuration>
              <descriptors>
                <descriptor>src/main/descriptors/main.xml</descriptor>
              </descriptors>
              <appendAssemblyId>false</appendAssemblyId>
              <tarLongFileMode>posix</tarLongFileMode>
              <!-- Don't install/publish the result -->
              <attach>false</attach>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
