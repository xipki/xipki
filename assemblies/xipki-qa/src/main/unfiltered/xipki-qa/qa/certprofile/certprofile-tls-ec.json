{
  "metadata": {
    "category": "A",
    "details": "certprofile tls"
  },
  "certLevel": "EndEntity",
  "maxSize": 8400,
  "validity": "5y",
  "notBeforeTime": "current",
  "keypairGeneration": "P256",
  "keyAlgorithms": [
    "BRAINPOOLP256R1",
    "BRAINPOOLP384R1",
    "BRAINPOOLP512R1",
    "FRP256V1",
    "P256",
    "P384",
    "P521",
    "SM2"
  ],
  "subject": [
    {
      "type": "country",
      "minOccurs": 0
    },
    {
      "type": "organization",
      "minOccurs": 0
    },
    {
      "type": "organizationalUnit",
      "minOccurs": 0
    },
    {
      "type": "serialNumber",
      "minOccurs": 0
    },
    {
      "type": "commonName",
      "toSAN": "DNSName",
      "regex": ":FQDN"
    }
  ],
  "extensions": [
    {
      "type": "SubjectKeyIdentifier",
      "required": true
    },
    {
      "type": "CRLDistributionPoints"
    },
    {
      "type": "FreshestCRL"
    },
    {
      "type": "SubjectAlternativeName",
      "required": true,
      "inRequest": "optional",
      "subjectAltName": {
        "modes": [
          "DNSName",
          "IPAddress"
        ]
      }
    },
    {
      "type": "BasicConstraints",
      "required": true,
      "critical": true
    },
    {
      "type": "AuthorityInfoAccess",
      "required": true,
      "authorityInfoAccess": {
        "includeCaIssuers": true,
        "includeOcsp": true
      }
    },
    {
      "type": "AuthorityKeyIdentifier",
      "required": true
    },
    {
      "type": "KeyUsage",
      "required": true,
      "critical": true,
      "inRequest": "optional",
      "keyUsage": {
        "usages": [
          {
            "required": [
              "dataEncipherment",
              "digitalSignature",
              "keyAgreement",
              "keyEncipherment"
            ]
          }
        ]
      }
    },
    {
      "type": "ExtendedKeyUsage",
      "required": true,
      "inRequest": "optional",
      "extendedKeyUsage": {
        "required": [
          "serverAuth"
        ],
        "optional": [
          "clientAuth"
        ]
      }
    }
  ]
}
