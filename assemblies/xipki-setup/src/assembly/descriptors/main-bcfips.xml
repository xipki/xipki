<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
  <id>bcfips</id>
  <includeBaseDirectory>true</includeBaseDirectory>
  <formats>
    <format>tar.gz</format>
  </formats>
  <fileSets>
    <!-- for all modules -->
    <fileSet>
      <directory>${project.build.outputDirectory}</directory>
      <outputDirectory>.</outputDirectory>
      <includes>
        <include>**/*.sh</include>
      </includes>
      <excludes>
        <exclude>bin/*.bat</exclude>
        <exclude>shared/**</exclude>
      </excludes>
      <fileMode>0755</fileMode>
      <directoryMode>0755</directoryMode>
      <lineEnding>unix</lineEnding>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}</directory>
      <outputDirectory>.</outputDirectory>
      <excludes>
        <exclude>**/*.sh</exclude>
        <exclude>**/mysql/**</exclude>
        <exclude>**/hsqldb/**</exclude>
        <exclude>shared/**</exclude>
        <exclude>xipki-mgmt-cli/xipki/sql/hsqldb/**</exclude>
        <exclude>xipki-mgmt-cli/xipki/sql/liquibase/**</exclude>
        <exclude>xipki-mgmt-cli/xipki/sql/ca-init-v7-sql/**</exclude>
      </excludes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <!-- tomcat shared files for xipki-ca -->
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-ca/tomcat</outputDirectory>
      <includes>
        <include>**/*.sh</include>
      </includes>
      <fileMode>0755</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-ca/tomcat</outputDirectory>
      <excludes>
        <exclude>**/*.sh</exclude>
      </excludes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <!-- tomcat shared files for xipki-gateway -->
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-gateway/tomcat</outputDirectory>
      <includes>
        <include>**/*.sh</include>
      </includes>
      <fileMode>0755</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-gateway/tomcat</outputDirectory>
      <excludes>
        <exclude>**/*.sh</exclude>
      </excludes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <!-- tomcat shared files for xipki-ocsp -->
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-ocsp/tomcat</outputDirectory>
      <includes>
        <include>**/*.sh</include>
      </includes>
      <fileMode>0755</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-ocsp/tomcat</outputDirectory>
      <excludes>
        <exclude>**/*.sh</exclude>
      </excludes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <!-- shared files for xipki-cli -->
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat/xipki/security</directory>
      <outputDirectory>xipki-cli/xipki/security</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <!-- shared files for xipki-mgmt-cli -->
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat/xipki/security</directory>
      <outputDirectory>xipki-mgmt-cli/xipki/security</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}/shared/tomcat</directory>
      <outputDirectory>xipki-gateway/tomcat</outputDirectory>
      <excludes>
        <exclude>**/*.sh</exclude>
      </excludes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <!-- folder t -->
    <fileSet>
      <directory>${project.build.directory}/t</directory>
      <outputDirectory>.</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.basedir}/../..</directory>
      <outputDirectory>.</outputDirectory>
      <includes>
        <include>README.md</include>
        <include>CHANGELOG.md</include>
      </includes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>

    <!-- xipki-mgmt-cli -->
    <fileSet>
      <directory>${project.build.directory}/t2/apache-karaf-minimal-${karaf.version}</directory>
      <outputDirectory>xipki-mgmt-cli</outputDirectory>
      <includes>
        <include>bin/*</include>
      </includes>
      <excludes>
        <exclude>bin/*.bat</exclude>
        <exclude>bin/inc</exclude>
      </excludes>
      <fileMode>0755</fileMode>
      <directoryMode>0755</directoryMode>
      <lineEnding>unix</lineEnding>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/t2/apache-karaf-minimal-${karaf.version}</directory>
      <outputDirectory>xipki-mgmt-cli</outputDirectory>
      <includes>
        <include>bin/*.bat</include>
        <include>bin/inc</include>
        <include>lib/**</include>
        <include>etc/**</include>
      </includes>
      <excludes>
        <exclude>etc/equinox-debug.properties</exclude>
        <exclude>etc/org.apache.karaf.features.repos.cfg</exclude>
        <exclude>etc/org.apache.karaf.jaas.cfg</exclude>
        <exclude>etc/org.apache.karaf.kar</exclude>
      </excludes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/t2/bc-fips/</directory>
      <outputDirectory>.</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>

    <!-- Tomcat -->
    <fileSet>
      <directory>${project.build.directory}/t2/xipki-ca/</directory>
      <outputDirectory>xipki-ca</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>

    <!-- database configuration files -->
    <fileSet>
      <directory>${project.build.outputDirectory}/xipki-ca/tomcat/xipki/etc/ca/database/mariadb</directory>
      <outputDirectory>xipki-ca/tomcat/xipki/etc/ca/database</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}/xipki-gateway/tomcat/xipki/etc/acme/database/mariadb</directory>
      <outputDirectory>xipki-gateway/tomcat/xipki/etc/acme/database</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
    <fileSet>
      <directory>${project.build.outputDirectory}/xipki-ocsp/tomcat/xipki/etc/ocsp/database/mariadb</directory>
      <outputDirectory>xipki-ocsp/tomcat/xipki/etc/ocsp/database</outputDirectory>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
  </fileSets>

  <files>
    <file>
      <source>${project.build.directory}/t2/apache-karaf-minimal-${karaf.version}/LICENSE</source>
      <outputDirectory>license</outputDirectory>
      <destName>karaf-LICENSE.json</destName>
      <fileMode>0644</fileMode>
    </file>
    <file>
      <source>${project.build.outputDirectory}/xipki-ca/tomcat/xipki/etc/ca/example/dbbased-ca.json</source>
      <outputDirectory>xipki-ca/tomcat/xipki/etc/ca</outputDirectory>
      <destName>ca.json</destName>
      <fileMode>0644</fileMode>
    </file>
    <file>
      <source>${project.build.outputDirectory}/xipki-ocsp/tomcat/xipki/etc/ocsp/example/xipki-ca-db-store/ocsp-responder.json</source>
      <outputDirectory>xipki-ocsp/tomcat/xipki/etc/ocsp</outputDirectory>
      <fileMode>0644</fileMode>
    </file>
  </files>
</assembly>
