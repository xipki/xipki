<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
  <id>thin</id>
  <includeBaseDirectory>true</includeBaseDirectory>
  <formats>
    <format>tar.gz</format>
  </formats>
  <fileSets>
    <!-- BouncyCastle Bridge jars -->
    <fileSet>
      <directory>${project.build.directory}/t2/setup/jars</directory>
      <outputDirectory>setup/jars</outputDirectory>
      <includes>
        <include>xipki/**</include>
      </includes>
      <fileMode>0644</fileMode>
      <directoryMode>0755</directoryMode>
    </fileSet>
  </fileSets>
  <componentDescriptors>
    <componentDescriptor>src/assembly/descriptors/dist-common.xml</componentDescriptor>
  </componentDescriptors>
</assembly>
