{
  "acme": {
    "baseUrl": "https://$[gateway.host]:$[gateway.https.port]/gw/acme/",
    "nonceNumBytes": 16,
    "tokenNumBytes": 16,
    "cacheSize": 1000,
    "syncDbSeconds": 60,
    "dbConf": "etc/acme/database/acme-db.properties",
    // Explicit opt-in for validating http-01 / tls-alpn-01 against private or
    // internal addresses. The secure default is false.
    //"allowPrivateChallengeTargets": false,
    // Enable DNSSEC verification for dns-01 challenge validation.
    //"dnssecValidation": true,
    // Optional explicit recursive resolvers. If unset, the host system DNS
    // configuration is used.
    //"dnsResolvers": [
    //  "1.1.1.1",
    //  "8.8.8.8"
    //],
    // Required if dnssecValidation is enabled. This file contains DNS root
    // trust anchors in DS or DNSKEY zone-file format.
    //"dnssecTrustAnchorsFile": "etc/acme/root-trust-anchors.zone",
    //"contactVerifier": "org.example.MyContactVerifier",
    //"termsOfService": "http://example.org/tos",
    "website": "http://example.org/doc/acme",
    //"caaIdentities": [
    //  "example.org"
    //],
    "challengeTypes": ["dns-01", "http-01", "tls-alpn-01"],
    "cleanupOrder": {
      "expiredCertDays": 390,
      "expiredOrderDays": 390
    },
    "caProfiles": [{
      "ca": "myca",
      "tlsProfile": "tls-ec",
      "keyTypes": ["1.2.840.10045.2.1"]
    }, {
      "ca": "myca",
      "tlsProfile": "tls-rsa",
      "keyTypes": ["1.2.840.113549.1.1.1"]
    }]
  }
}
