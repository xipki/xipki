<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>org.xipki.assembly</groupId>
    <artifactId>assemblies</artifactId>
    <version>6.7.0</version>
  </parent>
  <artifactId>xipki-setup</artifactId>
  <packaging>pom</packaging>
  <name>XiPKI :: ${project.artifactId}</name>
  <properties>
    <skipDeploy>false</skipDeploy>
  </properties>
  <dependencies>
    <dependency>
      <groupId>org.xipki.shell</groupId>
      <artifactId>xipki-cli</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>org.xipki.shell</groupId>
      <artifactId>xipki-mgmt-cli</artifactId>
      <version>${project.version}</version>
    </dependency>
  </dependencies>
  <build>
    <resources>
      <resource>
        <directory>src/assembly/unfiltered</directory>
        <filtering>false</filtering>
      </resource>
      <resource>
        <directory>src/assembly/filtered</directory>
        <filtering>true</filtering>
      </resource>
    </resources>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-resources-plugin</artifactId>
        <executions>
          <execution>
            <id>filter</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>resources</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.xipki.tools</groupId>
        <artifactId>dependency-maven-plugin</artifactId>
        <version>${xipki.dependency-plugin.version}</version>
        <executions>
          <execution>
            <id>download-mgmt-cli-shell</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>download</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/t2/xipki-mgmt-cli/lib</outputDirectory>
              <artifactItems>
                <artifactItem>
                  <groupId>org.xipki.shell</groupId>
                  <artifactId>xipki-mgmt-cli</artifactId>
                  <version>${project.version}</version>
                </artifactItem>
              </artifactItems>
            </configuration>
          </execution>
          <execution>
            <id>download-cli-shell</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>download</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/t2/xipki-cli/lib</outputDirectory>
              <artifactItems>
                <artifactItem>
                  <groupId>org.xipki.shell</groupId>
                  <artifactId>xipki-cli</artifactId>
                  <version>${project.version}</version>
                </artifactItem>
              </artifactItems>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-dependency-plugin</artifactId>
        <executions>
          <execution>
            <id>copy-wars</id>
            <phase>generate-resources</phase>
            <goals>
              <goal>copy</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/t2/webapps</outputDirectory>
              <stripVersion>true</stripVersion>
              <artifactItems>
                <artifactItem>
                  <groupId>org.xipki.servlet</groupId>
                  <artifactId>ca-servlet</artifactId>
                  <version>${project.version}</version>
                  <type>war</type>
                </artifactItem>
                <artifactItem>
                  <groupId>org.xipki.servlet</groupId>
                  <artifactId>ocsp-servlet</artifactId>
                  <version>${project.version}</version>
                  <type>war</type>
                </artifactItem>
                <artifactItem>
                  <groupId>org.xipki.servlet</groupId>
                  <artifactId>gateway-servlet</artifactId>
                  <version>${project.version}</version>
                  <type>war</type>
                </artifactItem>
              </artifactItems>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-assembly-plugin</artifactId>
        <executions>
          <execution>
            <id>main</id>
            <phase>package</phase>
            <goals>
              <goal>single</goal>
            </goals>
            <configuration>
              <descriptors>
                <descriptor>src/assembly/descriptors/dist-thin.xml</descriptor>
                <descriptor>src/assembly/descriptors/dist-bclts.xml</descriptor>
                <descriptor>src/assembly/descriptors/dist-bcfips.xml</descriptor>
              </descriptors>
              <attach>true</attach>
              <appendAssemblyId>true</appendAssemblyId>
              <tarLongFileMode>posix</tarLongFileMode>
              <recompressZippedFiles>true</recompressZippedFiles>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
